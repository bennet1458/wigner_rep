  },
  {
   "kind": 2,
   "value": "ClearAll[u, v,kx, kp, t1, t2, m, q, \\[HBar], \\[Sigma]x, \\[Sigma]p];\r\n\r\n(* -------------------------------\r\n   Full assumption set (IMPORTANT)\r\n-------------------------------- *)\r\n$Assumptions =\r\n  Element[{u, v, kx, kp, t1, t2, m, q, \\[HBar], \\[Sigma]x, \\[Sigma]p}, Reals] &&\r\n  \\[Sigma]x > 0 && \\[Sigma]p > 0 &&\r\n  m > 0 && q > 0 && t1 > 0 && t2 > 0 && \\[HBar] > 0;\r\n\r\n\r\n(* -------------------------------\r\n   Full function F(x,p)\r\n-------------------------------- *)\r\nF = Exp[-u^2/(2 \\[Sigma]x^2) - v^2/(2 \\[Sigma]p^2)];\r\n(* -------------------------------\r\n   2D Fourier transform\r\n   Convention: ∫∫ f(x,p) e^{-i(kx x + kp p)} dx dp\r\n-------------------------------- *)\r\n(* FT = FourierTransform[\r\n  F,\r\n  {x, p},\r\n  {kx, kp},\r\n  FourierParameters -> {1, 1}\r\n]; *)\r\n\r\nFT = Integrate[\r\n  F Exp[-I (kx u + kp v)] Exp[-I kx ((v+q) (t1 + t2) - q t1)/m] Exp[-I kp q], \r\n  {u, -Infinity, Infinity},\r\n  {v, -Infinity, Infinity},\r\n  Assumptions -> $Assumptions\r\n] // FullSimplify;\r\n\r\nFullSimplify[FT]\r\nTeXForm[FullSimplify[FT]]\r\n",
   "languageId": "wolfram",
   "outputs": [
    {
     "items": [
      {
       "data": "<div class=\"wexpr\"><wgraph class=\"resizable\" style=\"width:474px;height:33px;\" aspect-ratio=\"0.0693\" tabIndex=\"-1\"><img class=\"invert-brightness\" src=\"data:image/png;base64,\" /></wgraph></div>",
       "mime": "x-application/wolfram-language-html"
      }
     ],
     "id": "b29b00d2-29a7-4008-b48b-e5de2e497aa7"
    },
    {
     "items": [
      {
       "data": "2 \\pi  \\text{$\\sigma $p} \\text{$\\sigma $x} \\exp \\left(-\\frac{\\text{kp}^2 m^2 \\text{$\\sigma $p}^2+2 \\text{kp} m \\left(\\text{kx} \\text{$\\sigma $p}^2 (\\text{t1}+\\text{t2})+i m q\\right)+\\text{kx} \\left(\\text{kx} m^2 \\text{$\\sigma $x}^2+\\text{kx} \\text{$\\sigma $p}^2 (\\text{t1}+\\text{t2})^2+2 i m q \\text{t2}\\right)}{2 m^2}\\right)",
       "mime": "text/html"
      }
     ],
     "id": "0d55f7d5-9046-4434-a489-f47a58acffb2"
    }
   ],
   "metadata": {},
