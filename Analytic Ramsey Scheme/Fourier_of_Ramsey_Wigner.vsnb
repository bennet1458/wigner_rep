      {
       "data": "<div class=\"wexpr\"><wgraph class=\"resizable\" style=\"width:509px;height:67px;\" aspect-ratio=\"0.1321\" tabIndex=\"-1\"><img class=\"invert-brightness\" src=\"data:image/png;base64,\" /></wgraph></div>",
