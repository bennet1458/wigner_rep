{
 "cells": [
  {
   "kind": 2,
   "value": "ClearAll[x, p, kx, kp, t1, t2, m, q, \\[HBar], \\[Sigma]x, \\[Sigma]p];\r\n\r\n(* -------------------------------\r\n   Full assumption set (IMPORTANT)\r\n-------------------------------- *)\r\n$Assumptions =\r\n  Element[{x, p, kx, kp, t1, t2, m, q, \\[HBar], \\[Sigma]x, \\[Sigma]p}, Reals] &&\r\n  \\[Sigma]x > 0 && \\[Sigma]p > 0 &&\r\n  m > 0 && q > 0 && t1 > 0 && t2 > 0 && \\[HBar] > 0;\r\n\r\n(* -------------------------------\r\n   Gaussian w(x,p)\r\n-------------------------------- *)\r\nw[x_, p_] :=\r\n  Exp[-x^2/(2 \\[Sigma]x^2) - p^2/(2 \\[Sigma]p^2)];\r\n\r\n(* -------------------------------\r\n   Shifts\r\n-------------------------------- *)\r\nA1 = (p (t1 + t2) - q t1)/m;\r\nA2 = (p (t1 + t2) - (q t1)/2)/m;\r\nA3 = p (t1 + t2)/m;\r\n\r\n(* -------------------------------\r\n   Full function F(x,p)\r\n-------------------------------- *)\r\nF =\r\n  w[x - A1, p - q]\r\n  + 4 Cos[q (x - p t2/m)/\\[HBar]] Cos[q (x - A2)/\\[HBar]] w[x - A2, p - q]\r\n  + w[x - A3, p - q];\r\n\r\n(* -------------------------------\r\n   2D Fourier transform\r\n   Convention: ∫∫ f(x,p) e^{-i(kx x + kp p)} dx dp\r\n-------------------------------- *)\r\n(* FT = FourierTransform[\r\n  F,\r\n  {x, p},\r\n  {kx, kp},\r\n  FourierParameters -> {1, 1}\r\n]; *)\r\nFexp = Expand[TrigExpand[F]];\r\nFT = Integrate[\r\n  Fexp Exp[-I (kx x + kp p)],\r\n  {x, -Infinity, Infinity},\r\n  {p, -Infinity, Infinity},\r\n  Assumptions -> $Assumptions\r\n] // FullSimplify;\r\n\r\nFullSimplify[FT]\r\n",
   "languageId": "wolfram",
   "outputs": [
    {
     "items": [
      {
       "data": "<div class=\"wexpr\"><wgraph class=\"resizable\" style=\"width:174px;height:38px;\" aspect-ratio=\"0.2202\" tabIndex=\"-1\"><img class=\"invert-brightness\" src=\"data:image/png;base64,\" /></wgraph></div>",
       "mime": "x-application/wolfram-language-html"
