  },
  {
   "kind": 2,
   "value": "ClearAll[u, v,kx, kp, t1, t2, m, q, \\[HBar], \\[Sigma]x, \\[Sigma]p];\r\n\r\n(* -------------------------------\r\n   Full assumption set (IMPORTANT)\r\n-------------------------------- *)\r\n$Assumptions =\r\n  Element[{u, v, kx, kp, t1, t2, m, q, \\[HBar], \\[Sigma]x, \\[Sigma]p}, Reals] &&\r\n  \\[Sigma]x > 0 && \\[Sigma]p > 0 &&\r\n  m > 0 && q > 0 && t1 > 0 && t2 > 0 && \\[HBar] > 0;\r\n\r\n\r\n(* -------------------------------\r\n   Full function F(x,p)\r\n-------------------------------- *)\r\nF = Exp[-u^2/(2 \\[Sigma]x^2) - v^2/(2 \\[Sigma]p^2)];\r\nC1 = (Exp[I q/\\[HBar] (u+(v+q/2) t1/m)]+Exp[-I q/\\[HBar] (u+(v+q/2) t1/m)])/2;\r\nC2 = (Exp[I q/\\[HBar] u]+Exp[-I q/\\[HBar] u])/2;\r\n\r\n(* -------------------------------\r\n   2D Fourier transform\r\n   Convention: ∫∫ f(x,p) e^{-i(kx x + kp p)} dx dp\r\n-------------------------------- *)\r\n(* FT = FourierTransform[\r\n  F,\r\n  {x, p},\r\n  {kx, kp},\r\n  FourierParameters -> {1, 1}\r\n]; *)\r\n\r\nFT = Integrate[\r\n  F C1 C2 Exp[-I (kx u + kp v)] Exp[-I kx ((v+q) (t1 + t2) - q/2 t1)/m] Exp[-I kp q], \r\n  {u, -Infinity, Infinity},\r\n  {v, -Infinity, Infinity},\r\n  Assumptions -> $Assumptions\r\n] \r\n\r\nFT\r\nTeXForm[FullSimplify[FT]]\r\n",
   "languageId": "wolfram",
   "outputs": [
    {
     "items": [
      {
       "data": "<div class=\"wexpr\"><wgraph class=\"resizable\" style=\"width:1082px;height:131px;\" aspect-ratio=\"0.1213\" tabIndex=\"-1\"><img class=\"invert-brightness\" src=\"data:image/png;base64,\" /></wgraph></div>",
