    {
     "items": [
      {
       "data": "\\frac{1}{2} \\pi  \\text{$\\sigma $p} \\text{$\\sigma $x} \\exp \\left(-\\frac{q \\hbar  \\left(2 \\text{$\\sigma $p}^2 \\text{t1} (\\text{kp} m+\\text{kx} (\\text{t1}+\\text{t2}))+i m \\hbar  (2 \\text{kp} m+\\text{kx} (\\text{t1}+2 \\text{t2}))+2 (\\text{kx}+1) m^2 \\text{$\\sigma $x}^2\\right)+\\hbar ^2 \\left(\\text{$\\sigma $p}^2 (\\text{kp} m+\\text{kx} (\\text{t1}+\\text{t2}))^2+(\\text{kx}+1)^2 m^2 \\text{$\\sigma $x}^2\\right)+q^2 \\left(m^2 \\text{$\\sigma $x}^2+i m \\text{t1} \\hbar +\\text{$\\sigma $p}^2 \\text{t1}^2\\right)}{2 m^2 \\hbar ^2}\\right) \\left(\\exp \\left(\\frac{q \\left(2 (\\text{kx}+1) \\text{$\\sigma $x}^2+\\frac{\\text{t1} \\left(2 \\text{$\\sigma $p}^2 (\\text{kp} m+\\text{kx} (\\text{t1}+\\text{t2}))+i m q\\right)}{m^2}\\right)}{\\hbar }\\right)+\\exp \\left(\\frac{m q \\text{t1} \\left(2 \\text{kp} \\text{$\\sigma $p}^2+i q\\right)+2 \\text{kx} m^2 \\text{$\\sigma $x}^2 (q+\\hbar )+2 \\text{kx} q \\text{$\\sigma $p}^2 \\text{t1} (\\text{t1}+\\text{t2})}{m^2 \\hbar }\\right)+e^{\\frac{2 \\text{$\\sigma $x}^2 (\\text{kx} \\hbar +q)}{\\hbar }}+1\\right)",
       "mime": "text/html"
      }
     ],
     "id": "1bd481f4-a50a-480e-870e-02d3d8d3614c"
    }
   ],
