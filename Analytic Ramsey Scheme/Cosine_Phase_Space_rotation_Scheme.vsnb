  {
   "kind": 2,
   "value": "ClearAll[x, p, pp, q1, q2, hbar, eta, t0, t1, t2, m, w]\r\n\r\n(* Kernel T(x,p-p') *)\r\nT[x_, p_, pp_, q_] :=\r\n  1/2*\r\n  (DiracDelta[p - q - pp]\r\n  + 2 Cos[q x/hbar] DiracDelta[p - q/2 - pp]\r\n  + DiracDelta[p - pp]);\r\n\r\n\r\nPropagate[expr_, t_] :=\r\n   expr /. x -> x - p*t/m;\r\n\r\n\r\n",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "wt0 = Propagate[w[x, p], t0]\r\n\r\nwk1t0 =\r\n  Integrate[\r\n    T[x, p, pp, q1] * (wt0 /. p -> pp),\r\n    {pp, -Infinity, Infinity},\r\n    Assumptions -> {\r\n      Element[{p, q1, q2, x,t0, t1, t2, m, hbar}, Reals],\r\n      m > 0, hbar > 0\r\n    }\r\n  ] // FullSimplify\r\n\r\nwt1k1t0 = Propagate[wk1t0, t1]\r\n\r\nwk2t1k1t0 =\r\n    Integrate[\r\n        T[x, p, pp, q2] * (wt1k1t0 /. p -> pp),\r\n        {pp, -Infinity, Infinity},\r\n        Assumptions -> {\r\n        Element[{p, q1, q2, x,t0, t1, t2, m, hbar}, Reals],\r\n        m > 0, hbar > 0\r\n        }\r\n    ] // FullSimplify\r\n\r\nwt2k2t1k1t0 = Propagate[wk2t1k1t0, t2]\r\n\r\nInputForm[wt2k2t1k1t0]",
