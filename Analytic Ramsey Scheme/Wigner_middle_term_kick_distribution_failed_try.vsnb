  {
   "kind": 2,
   "value": "ClearAll[A, B, pd];\r\nreplaceAB = {\r\n (q2*(x-(p*t2)/m)) -> A,\r\n ((x - p*(t1 + t2)/m + q2*t1/(2m))) -> B,\r\n ((x - p*(t1 + t2)/m + q2*t1/(2m)))^2 -> B^2\r\n}\r\n\r\nreplacepd = {\r\n  p-q2/2 -> pd\r\n}\r\n\r\nFd = middleterm /. replaceAB\r\n\r\nFd2 = Fd /. replacepd\r\n\r\nInputForm[Fd2]",
