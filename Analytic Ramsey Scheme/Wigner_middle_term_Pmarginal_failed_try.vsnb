    {
     "items": [
      {
       "data": "(E^(-1/2*(-q + q1)^2/σq^2 - (-q + q2)^2/(2*σq^2) + ((q2*t1)/(2*m) - ((q1 + q2)*(t1 + t2))/(2*m) + x)^2/(2*σx^2) + (((t1 + t2)*((q2*t1)/(2*m) - ((q1 + q2)*(t1 + t2))/(2*m) + x))/(m*σx^2) + I*(-((q1*(-t1 - t2))/(m*ℏ)) + (q2*t2)/(m*ℏ)))^2/(4*(1/(2*σp^2) + (t1 + t2)^2/(2*m^2*σx^2))) - (q2*(-1/2*((q1 + q2)*t2)/m + x))/ℏ - (q1*((q2*t1)/(2*m) - ((q1 + q2)*(t1 + t2))/(2*m) + x))/ℏ)*Sqrt[(1/(2*σp^2) + (t1 + t2)^2/(2*m^2*σx^2))^(-1)])/(2*Sqrt[Pi]*σq^2) + (E^(-1/2*(-q + q1)^2/σq^2 - (-q + q2)^2/(2*σq^2) + ((q2*t1)/(2*m) - ((q1 + q2)*(t1 + t2))/(2*m) + x)^2/(2*σx^2) + (((t1 + t2)*((q2*t1)/(2*m) - ((q1 + q2)*(t1 + t2))/(2*m) + x))/(m*σx^2) + I*(-((q1*(-t1 - t2))/(m*ℏ)) - (q2*t2)/(m*ℏ)))^2/(4*(1/(2*σp^2) + (t1 + t2)^2/(2*m^2*σx^2))) + (q2*(-1/2*((q1 + q2)*t2)/m + x))/ℏ - (q1*((q2*t1)/(2*m) - ((q1 + q2)*(t1 + t2))/(2*m) + x))/ℏ)*Sqrt[(1/(2*σp^2) + (t1 + t2)^2/(2*m^2*σx^2))^(-1)])/(2*Sqrt[Pi]*σq^2) + (E^(-1/2*(-q + q1)^2/σq^2 - (-q + q2)^2/(2*σq^2) + ((q2*t1)/(2*m) - ((q1 + q2)*(t1 + t2))/(2*m) + x)^2/(2*σx^2) + (((t1 + t2)*((q2*t1)/(2*m) - ((q1 + q2)*(t1 + t2))/(2*m) + x))/(m*σx^2) + I*((q1*(-t1 - t2))/(m*ℏ) + (q2*t2)/(m*ℏ)))^2/(4*(1/(2*σp^2) + (t1 + t2)^2/(2*m^2*σx^2))) - (q2*(-1/2*((q1 + q2)*t2)/m + x))/ℏ + (q1*((q2*t1)/(2*m) - ((q1 + q2)*(t1 + t2))/(2*m) + x))/ℏ)*Sqrt[(1/(2*σp^2) + (t1 + t2)^2/(2*m^2*σx^2))^(-1)])/(2*Sqrt[Pi]*σq^2) + (E^(-1/2*(-q + q1)^2/σq^2 - (-q + q2)^2/(2*σq^2) + ((q2*t1)/(2*m) - ((q1 + q2)*(t1 + t2))/(2*m) + x)^2/(2*σx^2) + (((t1 + t2)*((q2*t1)/(2*m) - ((q1 + q2)*(t1 + t2))/(2*m) + x))/(m*σx^2) + I*((q1*(-t1 - t2))/(m*ℏ) - (q2*t2)/(m*ℏ)))^2/(4*(1/(2*σp^2) + (t1 + t2)^2/(2*m^2*σx^2))) + (q2*(-1/2*((q1 + q2)*t2)/m + x))/ℏ + (q1*((q2*t1)/(2*m) - ((q1 + q2)*(t1 + t2))/(2*m) + x))/ℏ)*Sqrt[(1/(2*σp^2) + (t1 + t2)^2/(2*m^2*σx^2))^(-1)])/(2*Sqrt[Pi]*σq^2)",
