    },
    {
     "items": [
      {
       "data": "E^(X^2/(2*σx^2))*(E^((((t1 + t2)*X)/(m*σx^2) + I*(-((q1*(-t1 - t2))/(m*ℏ)) + (q2*t2)/(m*ℏ)))^2/(4*M) - (q2*(-1/2*((q1 + q2)*t2)/m + x))/ℏ - (q1*X)/ℏ) + E^((((t1 + t2)*X)/(m*σx^2) + I*(-((q1*(-t1 - t2))/(m*ℏ)) - (q2*t2)/(m*ℏ)))^2/(4*M) + (q2*(-1/2*((q1 + q2)*t2)/m + x))/ℏ - (q1*X)/ℏ) + E^((((t1 + t2)*X)/(m*σx^2) + I*((q1*(-t1 - t2))/(m*ℏ) + (q2*t2)/(m*ℏ)))^2/(4*M) - (q2*(-1/2*((q1 + q2)*t2)/m + x))/ℏ + (q1*X)/ℏ) + E^((((t1 + t2)*X)/(m*σx^2) + I*((q1*(-t1 - t2))/(m*ℏ) - (q2*t2)/(m*ℏ)))^2/(4*M) + (q2*(-1/2*((q1 + q2)*t2)/m + x))/ℏ + (q1*X)/ℏ))*Sqrt[M^(-1)]*Sqrt[Pi]",
       "mime": "text/html"
