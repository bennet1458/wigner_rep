  {
   "kind": 2,
   "value": "chit2k2t1k1 // Expand;\r\nchit2k2t1k1 = chit2k2t1k1 //. {\r\n   Exp[a_]/Exp[b_] :> Exp[Expand[a - b]],\r\n   Exp[a_]*Exp[b_] :> Exp[Expand[a + b]]\r\n};\r\n\r\nCanonicalChi[expr_] :=\r\n Module[{tmp = Expand[expr]},\r\n  tmp //. {\r\n     s - t1*w - t2*w :> s - (t1+t2) w,\r\n\r\n     s - t2*w - t1*(q2 + m*w)/m :>\r\n        s - (t1+t2) w - q2*t1/m,\r\n\r\n     s + q2*t1/m - t1*w - t2*w :>\r\n        s - (t1+t2) w + q2*t1/m\r\n   } //\r\n   Collect[#, _chi] &\r\n ]\r\n\r\n CanonicalExponent[expr_] :=\r\n expr //. Exp[a_] :>\r\n   Exp[\r\n     Collect[\r\n       Expand[a],\r\n       {w, s},\r\n       Factor\r\n     ]\r\n   ];\r\n\r\nchit2k2t1k1 // Expand\r\nchit2k2t1k1 =CanonicalChi[chit2k2t1k1]\r\nchit2k2t1k1 = CanonicalExponent[chit2k2t1k1]\r\nInputForm[chit2k2t1k1]\r\nchit2k2t1k1 // FullSimplify;\r\n",
   "languageId": "wolfram",
   "outputs": [
