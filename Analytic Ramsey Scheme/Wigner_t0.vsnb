{
 "cells": [
  {
   "kind": 2,
   "value": "ClearAll[w, wd, s, q,q1, q2, hbar, t1, t2, m, chi]\r\n\r\n(* Kernel T(x,p-p') *)\r\nT[w_, s_, wd_, q_] :=\r\n  1/4*((1+Exp[-I/hbar*q*s]) DiracDelta[w - wd] +\r\n  Exp[-I/hbar*q*s]*(DiracDelta[w - q/m - wd]+DiracDelta[w + q/m - wd]));\r\n\r\nPropagate[expr_, t_] :=\r\n   expr /. s -> s - w*t;\r\n(* Propagate[expr_, t_] :=\r\n    expr /. chi[a_, b_] :> chi[a, b - a*t] *)\r\n\r\n",
   "languageId": "wolfram",
   "outputs": [
    {
     "items": [
