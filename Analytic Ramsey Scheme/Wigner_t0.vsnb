       "data": "<div class=\"wexpr\"><wgraph class=\"resizable\" style=\"width:1002px;height:229px;\" aspect-ratio=\"0.2284\" tabIndex=\"-1\"><img class=\"invert-brightness\" src=\"data:image/png;base64,\" /></wgraph></div>",
