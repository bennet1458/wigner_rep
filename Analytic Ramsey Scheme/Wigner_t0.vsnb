       "data": "chi[w, s - (t1 + t2)*w]/16 + (E^(((-I)*q2*s)/hbar + (I*q2*t2*w)/hbar)*chi[w, s - (t1 + t2)*w])/16 + (E^(((-I)*q1*s)/hbar + (I*q1*(t1 + t2)*w)/hbar)*chi[w, s - (t1 + t2)*w])/16 + (E^(((-I)*(q1 + q2)*s)/hbar + (I*(q1*t1 + q1*t2 + q2*t2)*w)/hbar)*chi[w, s - (t1 + t2)*w])/16 + (E^(((-I)*q1*s)/hbar + (I*q1*(t1 + t2)*w)/hbar)*chi[-(q1/m) + w, s - (t1 + t2)*w])/16 + (E^(((-I)*(q1 + q2)*s)/hbar + (I*(q1*t1 + q1*t2 + q2*t2)*w)/hbar)*chi[-(q1/m) + w, s - (t1 + t2)*w])/16 + (E^(((-I)*q1*s)/hbar + (I*q1*(t1 + t2)*w)/hbar)*chi[q1/m + w, s - (t1 + t2)*w])/16 + (E^(((-I)*(q1 + q2)*s)/hbar + (I*(q1*t1 + q1*t2 + q2*t2)*w)/hbar)*chi[q1/m + w, s - (t1 + t2)*w])/16 + (E^(((-I)*(q1 + q2)*s)/hbar - (I*q1*q2*t1)/(hbar*m) + (I*(q1*t1 + q1*t2 + q2*t2)*w)/hbar)*chi[(q1 - q2)/m + w, s + (q2*t1)/m - (t1 + t2)*w])/16 + (E^(((-I)*q2*s)/hbar + (I*q2*t2*w)/hbar)*chi[-(q2/m) + w, s + (q2*t1)/m - (t1 + t2)*w])/16 + (E^(((-I)*(q1 + q2)*s)/hbar - (I*q1*q2*t1)/(hbar*m) + (I*(q1*t1 + q1*t2 + q2*t2)*w)/hbar)*chi[-(q2/m) + w, s + (q2*t1)/m - (t1 + t2)*w])/16 + (E^(((-I)*q2*s)/hbar + (I*q2*t2*w)/hbar)*chi[q2/m + w, s - (q2*t1)/m - (t1 + t2)*w])/16 + (E^(((-I)*(q1 + q2)*s)/hbar + (I*q1*q2*t1)/(hbar*m) + (I*(q1*t1 + q1*t2 + q2*t2)*w)/hbar)*chi[q2/m + w, s - (q2*t1)/m - (t1 + t2)*w])/16 + (E^(((-I)*(q1 + q2)*s)/hbar - (I*q1*q2*t1)/(hbar*m) + (I*(q1*t1 + q1*t2 + q2*t2)*w)/hbar)*chi[-((q1 + q2)/m) + w, s + (q2*t1)/m - (t1 + t2)*w])/16 + (E^(((-I)*(q1 + q2)*s)/hbar + (I*q1*q2*t1)/(hbar*m) + (I*(q1*t1 + q1*t2 + q2*t2)*w)/hbar)*chi[(q1 + q2)/m + w, s - (q2*t1)/m - (t1 + t2)*w])/16 + (E^(((-I)*(q1 + q2)*s)/hbar + (I*q1*q2*t1)/(hbar*m) + (I*(q1*t1 + q1*t2 + q2*t2)*w)/hbar)*chi[(-q1 + q2 + m*w)/m, s - (q2*t1)/m - (t1 + t2)*w])/16 //. {s - (t1 + t2)*w :> s - (t1 + t2)*w, s - (q2*t1)/m - (t1 + t2)*w :> s - (t1 + t2)*w - q2*(t1/m), s + (q2*t1)/m - (t1 + t2)*w :> s - (t1 + t2)*w + q2*(t1/m), Null}",
