    {
     "items": [
      {
       "data": "(E^((I*q1*t1*(q2 - m*w))/(hbar*m))*(E^((I*q1*t1*w)/hbar) + E^((I*q1*(s - t2*w))/hbar))*(1 + E^((I*q2*(s - t2*w))/hbar))*chi[w, s - t1*w - t2*w] + E^((I*q1*q2*t1)/(hbar*m))*(1 + E^((I*q2*(s - t2*w))/hbar))*chi[-(q1/m) + w, s - t1*w - t2*w] + E^((I*q1*q2*t1)/(hbar*m))*chi[q1/m + w, s - t1*w - t2*w] + E^((I*q2*(q1*t1 + m*(s - t2*w)))/(hbar*m))*chi[q1/m + w, s - t1*w - t2*w] + chi[(q1 - q2)/m + w, s + (q2*t1)/m - t1*w - t2*w] + chi[-(q2/m) + w, s + (q2*t1)/m - t1*w - t2*w] + E^(((2*I)*q1*q2*t1)/(hbar*m))*chi[q2/m + w, s - t2*w - (t1*(q2 + m*w))/m] + E^((I*q1*(q2*t1 - m*t1*w + m*(s - t2*w)))/(hbar*m))*(chi[-(q2/m) + w, s + (q2*t1)/m - t1*w - t2*w] + chi[q2/m + w, s - t2*w - (t1*(q2 + m*w))/m]) + chi[-((q1 + q2)/m) + w, s + (q2*t1)/m - t1*w - t2*w] + E^(((2*I)*q1*q2*t1)/(hbar*m))*chi[(q1 + q2)/m + w, s - t2*w - (t1*(q2 + m*w))/m] + E^(((2*I)*q1*q2*t1)/(hbar*m))*chi[(-q1 + q2 + m*w)/m, s - t2*w - (t1*(q2 + m*w))/m])/(16*E^((I*(q1*q2*t1 - m*q1*t1*w + m*(q1 + q2)*(s - t2*w)))/(hbar*m)))",
       "mime": "text/html"
      }
     ],
