       "data": "<div class=\"wexpr\"><wgraph class=\"resizable\" style=\"width:1010px;height:190px;\" aspect-ratio=\"0.1876\" tabIndex=\"-1\"><img class=\"invert-brightness\" src=\"data:image/png;base64,\" /></wgraph></div>",
