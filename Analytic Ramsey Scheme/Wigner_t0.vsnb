       "data": "<div class=\"wexpr\"><wgraph class=\"resizable\" style=\"width:536px;height:32px;\" aspect-ratio=\"0.0597\" tabIndex=\"-1\"><img class=\"invert-brightness\" src=\"data:image/png;base64,\" /></wgraph></div>",
