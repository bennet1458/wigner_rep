  },
  {
   "kind": 2,
   "value": "chik1 =\r\n  Integrate[\r\n    T[w, s, wd, q1] * (chi[w, s] /. w -> wd),\r\n    {wd, -Infinity, Infinity},\r\n    Assumptions -> {\r\n      Element[{w, wd, s, q,q1, q2, hbar, t1, t2, m}, Reals],\r\n      m > 0, hbar > 0\r\n    }\r\n  ] // FullSimplify;\r\n\r\n  (* expanded = Expand[expr] // FullSimplify *)\r\n  (* TeXForm[expanded] *)\r\n\r\nchik1 \r\n\r\nchit1k1 = Propagate[chik1, t1]\r\n\r\nchik2t1k1 =\r\n  Integrate[\r\n    T[w, s, wd, q2] * (chit1k1 /. w -> wd),\r\n    {wd, -Infinity, Infinity},\r\n    Assumptions -> {\r\n      Element[{w, wd, s, q,q1, q2, hbar, t1, t2, m}, Reals],\r\n      m > 0, hbar > 0\r\n    }\r\n  ] // FullSimplify;\r\n\r\n  (* expanded = Expand[expr] // FullSimplify *)\r\n  (* TeXForm[expanded] *)\r\n\r\nchik2t1k1 \r\n\r\nchit2k2t1k1 = Propagate[chik2t1k1, t2] \r\nInputForm[chit2k2t1k1] \r\n",
   "languageId": "wolfram",
   "outputs": [
    {
     "items": [
      {
       "data": "<div class=\"wexpr\"><wgraph class=\"resizable\" style=\"width:486px;height:32px;\" aspect-ratio=\"0.0659\" tabIndex=\"-1\"><img class=\"invert-brightness\" src=\"data:image/png;base64,\" /></wgraph></div>",
