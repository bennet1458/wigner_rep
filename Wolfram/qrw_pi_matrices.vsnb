{
 "cells": [
  {
   "kind": 2,
   "value": "(* Clear previous definitions *)\r\nClearAll[k, lambdaPlus, lambdaMinus, vPlus, vMinus, P, PiPlus, PiMinus];\r\n\r\n(* Eigenvalues *)\r\nlambdaPlus = 1/2 ((Exp[-I k] - 1)/Sqrt[2] +\r\n     Sqrt[((1 - Exp[-I k])^2)/2 + 4 Exp[-I k]]);\r\n\r\nlambdaMinus = 1/2 ((Exp[-I k] - 1)/Sqrt[2] -\r\n     Sqrt[((1 - Exp[-I k])^2)/2 + 4 Exp[-I k]]);\r\n\r\n(* Eigenvectors *)\r\nvPlus = {1, Sqrt[2] Exp[I k] lambdaPlus - 1};\r\nvMinus = {1, Sqrt[2] Exp[I k] lambdaMinus - 1};\r\n\r\n(* Matrix of eigenvectors *)\r\nP = Transpose[{vPlus, vMinus}];\r\n\r\n(* Projectors *)\r\nPiPlus = FullSimplify[\r\n   P . {{1, 0}, {0, 0}} . Inverse[P]\r\n   ];\r\n\r\nPiMinus = FullSimplify[\r\n   P . {{0, 0}, {0, 1}} . Inverse[P]\r\n   ];\r\n\r\n(* Display the projectors *)\r\nPiPlus // MatrixForm\r\nPiMinus // MatrixForm\r\nTeXForm[PiPlus]\r\nTeXForm[PiMinus]\r\n\r\n",
   "languageId": "wolfram",
   "outputs": [
    {
     "items": [
      {
       "data": "<div class=\"wexpr\"><wgraph class=\"resizable\" style=\"width:365px;height:70px;\" aspect-ratio=\"0.1930\" tabIndex=\"-1\"><img class=\"invert-brightness\" src=\"data:image/png;base64,\" /></wgraph></div>",
       "mime": "x-application/wolfram-language-html"
      }
     ],
     "id": "557cbfab-7143-4651-a396-27141627717f"
