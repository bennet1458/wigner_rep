    {
     "items": [
      {
       "data": "\\left(\n\\begin{array}{cc}\n \\frac{e^{-i k}+\\sqrt{2} \\sqrt{e^{-i k} (\\cos (k)+3)}+1}{2 \\sqrt{2} \\sqrt{e^{-i k} (\\cos (k)+3)}} & \\frac{\\sqrt{e^{-i k} (\\cos (k)+3)}}{\\sqrt{2} (\\cos (k)+3)} \\\\\n \\frac{1}{\\sqrt{2} \\sqrt{e^{-i k} (\\cos (k)+3)}} & \\frac{-e^{-i k}+\\sqrt{2} \\sqrt{e^{-i k} (\\cos (k)+3)}-1}{2 \\sqrt{2} \\sqrt{e^{-i k} (\\cos (k)+3)}} \\\\\n\\end{array}\n\\right)",
       "mime": "text/html"
      }
