    {
     "items": [
      {
       "data": "Sqrt[a^(-1)]*E^(F2^2/(4*a) - F1^2/(4*a*hbar^2) - (F1*M2*q2)/(2*a*hbar^2) - (F2*M3*q2)/(2*a) - (M2^2*q2^2)/(4*a*hbar^2) + (M3^2*q2^2)/(4*a) - p^2/(2*σp^2) + (p*q2)/(2*σp^2) - q2^2/(8*σp^2) - q^2/(2*σq^2) - F1^2/(2*σx^2) - (F1*M2*q2)/σx^2 - (M2^2*q2^2)/(2*σx^2))*(E^(((I/2)*F1*F2)/(a*hbar) - M1*q2 + ((I/2)*F2*M2*q2)/(a*hbar) - ((I/2)*F1*M3*q2)/(a*hbar) - ((I/2)*M2*M3*q2^2)/(a*hbar)) + E^(((I/2)*F1*F2)/(a*hbar) + M1*q2 + ((I/2)*F2*M2*q2)/(a*hbar) - ((I/2)*F1*M3*q2)/(a*hbar) - ((I/2)*M2*M3*q2^2)/(a*hbar)) + E^(((-1/2*I)*F1*F2)/(a*hbar) - M1*q2 - ((I/2)*F2*M2*q2)/(a*hbar) + ((I/2)*F1*M3*q2)/(a*hbar) + ((I/2)*M2*M3*q2^2)/(a*hbar)) + E^(((-1/2*I)*F1*F2)/(a*hbar) + M1*q2 - ((I/2)*F2*M2*q2)/(a*hbar) + ((I/2)*F1*M3*q2)/(a*hbar) + ((I/2)*M2*M3*q2^2)/(a*hbar)))*Sqrt[Pi]",
       "mime": "text/html"
      }
