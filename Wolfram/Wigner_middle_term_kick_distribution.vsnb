       "data": "<div class=\"wexpr\"><wgraph class=\"resizable\" style=\"width:414px;height:39px;\" aspect-ratio=\"0.0946\" tabIndex=\"-1\"><img class=\"invert-brightness\" src=\"data:image/png;base64,\" /></wgraph></div>",
