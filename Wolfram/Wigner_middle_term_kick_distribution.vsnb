    },
    {
     "items": [
      {
       "data": "Sqrt[a^(-1)]*E^(bf^2/(4*a) + bt^2/(4*a) + cf)*(E^(-1/2*(bf*bt)/a - ct) + E^((bf*bt)/(2*a) - ct) + E^(-1/2*(bf*bt)/a + ct) + E^((bf*bt)/(2*a) + ct))*Sqrt[Pi]",
       "mime": "text/html"
      }
     ],
     "id": "2173b4f8-bc6a-4ec2-b475-4695b9f09504"
    }
   ],
   "metadata": {},
   "executionSummary": {}
