  {
   "kind": 2,
   "value": "replacebc = {\r\n bf -> -pd/(2 \\[Sigma]p^2) - q/\\[Sigma]q^2,\r\n bt -> I*B/hbar,\r\n cf -> -B^2/(2 \\[Sigma]x^2) - pd^2/(2 \\[Sigma]p^2) - q^2/(2 \\[Sigma]q^2),\r\n ct -> I*A/hbar\r\n};\r\n\r\nres3 = res2 /. replacebc\r\n\r\nireplaceAB = Reverse /@ replaceAB;\r\nres4 = res3 /. ireplaceAB\r\n\r\nireplacepd = Reverse /@ replacepd;\r\nres5 = res4 /. ireplacepd",
   "languageId": "wolfram",
