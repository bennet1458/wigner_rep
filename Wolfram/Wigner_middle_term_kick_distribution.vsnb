     ],
     "id": "86874bd0-7f3c-457e-ad86-f8d65c2efcb3"
    },
    {
     "items": [
      {
       "data": "Sqrt[a^(-1)]*E^(-1/4*(F1 + M2*q2)^2/(a*hbar^2) + (-F2 + M3*q2)^2/(4*a) - (p - q2/2)^2/(2*σp^2) - q^2/(2*σq^2) - (F1 + M2*q2)^2/(2*σx^2))*(E^(-(M1*q2) - ((I/2)*(F1 + M2*q2)*(-F2 + M3*q2))/(a*hbar)) + E^(M1*q2 - ((I/2)*(F1 + M2*q2)*(-F2 + M3*q2))/(a*hbar)) + E^(-(M1*q2) + ((I/2)*(F1 + M2*q2)*(-F2 + M3*q2))/(a*hbar)) + E^(M1*q2 + ((I/2)*(F1 + M2*q2)*(-F2 + M3*q2))/(a*hbar)))*Sqrt[Pi]",
       "mime": "text/html"
      }
     ],
     "id": "7e8ade66-6fcb-424b-b362-0d17913a91f9"
    }
