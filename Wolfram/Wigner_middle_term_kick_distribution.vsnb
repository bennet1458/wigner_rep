    {
     "items": [
      {
       "data": "E^(((-I)*A)/hbar - (I*B*q1)/hbar - (pd - q1/2)^2/(2*σp^2) - (-q + q1)^2/(2*σq^2) - (B^2*q1^2)/(2*σx^2))/(Sqrt[2*Pi]*σq) + E^((I*A)/hbar - (I*B*q1)/hbar - (pd - q1/2)^2/(2*σp^2) - (-q + q1)^2/(2*σq^2) - (B^2*q1^2)/(2*σx^2))/(Sqrt[2*Pi]*σq) + E^(((-I)*A)/hbar + (I*B*q1)/hbar - (pd - q1/2)^2/(2*σp^2) - (-q + q1)^2/(2*σq^2) - (B^2*q1^2)/(2*σx^2))/(Sqrt[2*Pi]*σq) + E^((I*A)/hbar + (I*B*q1)/hbar - (pd - q1/2)^2/(2*σp^2) - (-q + q1)^2/(2*σq^2) - (B^2*q1^2)/(2*σx^2))/(Sqrt[2*Pi]*σq)",
       "mime": "text/html"
      }
