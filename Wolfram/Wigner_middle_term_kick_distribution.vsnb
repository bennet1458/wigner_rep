{
 "cells": [
  {
   "kind": 2,
   "value": "ClearAll[x, p, \\[Sigma]x, \\[Sigma]p];\r\n\r\n$Assumptions =\r\n  Element[{x, p, \\[Sigma]x, \\[Sigma]p}, Reals] &&\r\n  \\[Sigma]x > 0 && \\[Sigma]p > 0;\r\n  \r\nw[x_, p_] :=\r\n  Exp[-x^2/(2 \\[Sigma]x^2) - p^2/(2 \\[Sigma]p^2)]",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "middleterm = (2*Cos[q2*(x-(p*t2)/m)/hbar]\r\n                *2*Cos[q1*(x - p*(t1 + t2)/m + q2*t1/(2m))/hbar]\r\n                *w[q1*(x - p*(t1 + t2)/m + q2*t1/(2m)), p - q1/2 - q2/2]\r\n              )",
   "languageId": "wolfram",
   "outputs": [
    {
     "items": [
      {
       "data": "<div class=\"wexpr\"><wgraph class=\"resizable\" style=\"width:566px;height:47px;\" aspect-ratio=\"0.0835\" tabIndex=\"-1\"><img class=\"invert-brightness\" src=\"data:image/png;base64,\" /></wgraph></div>",
