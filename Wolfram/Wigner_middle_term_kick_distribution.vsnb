  {
   "kind": 2,
   "value": "ClearAll[q1,q2,q,\\[Sigma]q]\r\n\r\nP[z_] := Exp[-(z-q)^2/(2 \\[Sigma]q^2)]/(Sqrt[2 Pi] \\[Sigma]q);\r\n",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "expr =\r\n  P[q1] Fd2 // TrigToExp //Expand\r\n\r\nInputForm[expr]\r\n",
   "languageId": "wolfram",
   "outputs": [
    {
     "items": [
      {
       "data": "<div class=\"wexpr\"><wgraph class=\"resizable\" style=\"width:946px;height:62px;\" aspect-ratio=\"0.0660\" tabIndex=\"-1\"><img class=\"invert-brightness\" src=\"data:image/png;base64,\" /></wgraph></div>",
