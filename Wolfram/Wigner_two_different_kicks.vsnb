       "data": "<div class=\"wexpr\"><wgraph class=\"resizable\" style=\"width:150px;height:38px;\" aspect-ratio=\"0.2567\" tabIndex=\"-1\"><img class=\"invert-brightness\" src=\"data:image/png;base64,\" /></wgraph></div>",
