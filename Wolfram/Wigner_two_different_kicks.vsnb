  {
   "kind": 2,
   "value": "ClearAll[A, B, pd];\r\nF = expr\r\n\r\nFd = F /. {\r\n ((q2*t1)/(2*m) - ((q1+q2)(t1+t2))/(2*m) + x) -> X,\r\n 1/(2 \\[Sigma]p^2) + (t1+t2)^2/(2 m^2 \\[Sigma]x^2) -> M\r\n}\r\n\r\n\r\nFd2 = Fd /. {(t1+t2) X/(m \\[Sigma]x^2) -> a,\r\n q1 (-t1-t2)/(m \\[HBar]) -> -b,\r\n q2 t2/(m \\[HBar]) -> c\r\n}\r\n\r\nFd3 = Fd2/. {(q2*(-1/2*((q1 + q2)*t2)/m + x))/\\[HBar] -> d,\r\n (q1*X)/\\[HBar] -> e\r\n}\r\n\r\n\r\nInputForm[Fd3]",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "intExp = Integrate[\r\n   P[q1] Exp[I q1 X/hbar],\r\n   {q1,-Infinity,Infinity},\r\n   Assumptions -> {sigma > 0, Element[{q,X,hbar}, Reals]}\r\n];\r\n\r\nex = ExpToTrig[ComplexExpand[Re[intExp]]] // FullSimplify\r\nInputForm[ex]",
   "languageId": "wolfram",
