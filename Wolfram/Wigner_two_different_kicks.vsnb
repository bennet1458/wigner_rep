  {
   "kind": 2,
   "value": "(* middletermexp[q1_,q2_] = ((w[-((p*(t1 + t2))/m) + x, p - q1] )\r\n              + 2*Exp[I*(q2*(-((p*t2)/m) + x))/hbar]\r\n                *2*Exp[I*(q1*(q2*t1 - 2*p*(t1 + t2) + 2*m*x))/(2*hbar*m)]\r\n                *w[(q2*t1 - 2*p*(t1 + t2) + 2*m*x)/(2*m), p - q1/2 - q2/2]\r\n              + w[(q2*t1 - p*(t1 + t2) + m*x)/m, p - q2]) *)\r\n\r\nmiddletermexp[q1_,q2_] = (\r\n              2*Exp[I*(q2*(-((p*t2)/m) + x))/hbar]\r\n                *2*Exp[I*(q1*(q2*t1 - 2*p*(t1 + t2) + 2*m*x))/(2*hbar*m)]\r\n                *w[(q2*t1 - 2*p*(t1 + t2) + 2*m*x)/(2*m), p - q1/2 - q2/2]\r\n              )",
