    {
     "items": [
      {
       "data": "2 w\\left(\\frac{m x-p (\\text{t1}+\\text{t2})+\\text{q2} \\text{t1}}{m},p-\\frac{\\text{q1}}{2}-\\text{q2}\\right) \\cos \\left(\\frac{\\text{q1} (m x-p (\\text{t1}+\\text{t2})+\\text{q2} \\text{t1})}{\\text{hbar} m}\\right)+2 \\cos \\left(\\frac{\\text{q2} \\left(x-\\frac{p \\text{t2}}{m}\\right)}{\\text{hbar}}\\right) \\left(2 w\\left(\\frac{2 m x-2 p (\\text{t1}+\\text{t2})+\\text{q2} \\text{t1}}{2 m},p-\\frac{\\text{q1}}{2}-\\frac{\\text{q2}}{2}\\right) \\cos \\left(\\frac{\\text{q1} (2 m x-2 p (\\text{t1}+\\text{t2})+\\text{q2} \\text{t1})}{2 \\text{hbar} m}\\right)+w\\left(\\frac{2 m x-2 p (\\text{t1}+\\text{t2})+\\text{q2} \\text{t1}}{2 m},p-\\text{q1}-\\frac{\\text{q2}}{2}\\right)+w\\left(\\frac{2 m x-2 p (\\text{t1}+\\text{t2})+\\text{q2} \\text{t1}}{2 m},p-\\frac{\\text{q2}}{2}\\right)\\right)+2 w\\left(x-\\frac{p (\\text{t1}+\\text{t2})}{m},p-\\frac{\\text{q1}}{2}\\right) \\cos \\left(\\frac{\\text{q1} (p (\\text{t1}+\\text{t2})-m x)}{\\text{hbar} m}\\right)+w\\left(\\frac{m x-p (\\text{t1}+\\text{t2})+\\text{q2} \\text{t1}}{m},p-\\text{q1}-\\text{q2}\\right)+w\\left(x-\\frac{p (\\text{t1}+\\text{t2})}{m},p-\\text{q1}\\right)+w\\left(\\frac{m x-p (\\text{t1}+\\text{t2})+\\text{q2} \\text{t1}}{m},p-\\text{q2}\\right)+w\\left(x-\\frac{p (\\text{t1}+\\text{t2})}{m},p\\right)",
       "mime": "text/html"
      }
     ],
     "id": "fce339ce-7f09-474c-a05a-9eb1ff874c8b"
    },
    {
     "items": [
      {
       "data": "w[-((p*(t1 + t2))/m) + x, p] + w[-((p*(t1 + t2))/m) + x, p - q1] + 2*Cos[(q1*(p*(t1 + t2) - m*x))/(hbar*m)]*w[-((p*(t1 + t2))/m) + x, p - q1/2] + w[(q2*t1 - p*(t1 + t2) + m*x)/m, p - q2] + w[(q2*t1 - p*(t1 + t2) + m*x)/m, p - q1 - q2] + 2*Cos[(q1*(q2*t1 - p*(t1 + t2) + m*x))/(hbar*m)]*w[(q2*t1 - p*(t1 + t2) + m*x)/m, p - q1/2 - q2] + 2*Cos[(q2*(-((p*t2)/m) + x))/hbar]*(w[(q2*t1 - 2*p*(t1 + t2) + 2*m*x)/(2*m), p - q2/2] + w[(q2*t1 - 2*p*(t1 + t2) + 2*m*x)/(2*m), p - q1 - q2/2] + 2*Cos[(q1*(q2*t1 - 2*p*(t1 + t2) + 2*m*x))/(2*hbar*m)]*w[(q2*t1 - 2*p*(t1 + t2) + 2*m*x)/(2*m), p - q1/2 - q2/2])",
       "mime": "text/html"
      }
     ],
     "id": "bf064d44-93a1-439e-80a5-4a4e407bfb88"
    }
