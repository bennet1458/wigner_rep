 "cells": [
  {
   "kind": 2,
   "value": "ClearAll[x, p, pp, q, hbar, eta, t1, m, w]\r\n\r\n(* Kernel T(x,p-p') *)\r\nT[x_, p_, pp_] :=\r\n  eta^2 DiracDelta[p - q - pp] +\r\n  eta (1 - eta) 2 Cos[q x/hbar] DiracDelta[p - q/2 - pp] +\r\n  (1 - eta)^2 DiracDelta[p - pp];\r\n\r\n(* w_{ε,k}(x,p') *)\r\nwek[x_, pp_] :=\r\n  (eta^2 w[x - pp t1/m, pp - q] +\r\n  2 eta (1 - eta)\r\n    Cos[(q/hbar) (x - pp t1/m)]\r\n    w[x - pp t1/m, pp - q/2] +\r\n  (1 - eta)^2\r\n    w[x - pp t1/m, pp]);\r\n\r\n(* Convolution *)\r\nexpr =\r\n  Integrate[\r\n    T[x, p, pp] * wek[x, pp],\r\n    {pp, -Infinity, Infinity},\r\n    Assumptions -> {\r\n      Element[{p, q, x, eta, t1, m, hbar}, Reals],\r\n      m > 0, hbar > 0\r\n    }\r\n  ] // FullSimplify\r\n\r\n  (* expanded = Expand[expr] // FullSimplify *)\r\n  (* TeXForm[expanded] *)\r\n\r\nexpr // Expand // Collect[#, _w, FullSimplify] &",
   "languageId": "wolfram",
   "outputs": [
    {
     "items": [
