       "data": "<div class=\"wexpr\"><wgraph class=\"resizable\" style=\"width:1068px;height:265px;\" aspect-ratio=\"0.2479\" tabIndex=\"-1\"><img class=\"invert-brightness\" src=\"data:image/png;base64,\" /></wgraph></div>",
