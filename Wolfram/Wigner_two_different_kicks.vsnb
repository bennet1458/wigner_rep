  {
   "kind": 2,
   "value": "ClearAll[q1,q2,q,\\[Sigma]q]\r\n\r\nP[z_] := Exp[-(z-q)^2/(2 \\[Sigma]q^2)]/(Sqrt[2 Pi] \\[Sigma]q);\r\n",
   "languageId": "wolfram",
   "outputs": [],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "expr =\r\n  P[q1] P[q2] middletermexp[q1,q2] // Expand\r\n\r\nInputForm[expr]\r\n",
   "languageId": "wolfram",
   "outputs": [
