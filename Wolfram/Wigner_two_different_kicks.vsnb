    {
     "items": [
      {
       "data": "(2*E^((I*q2*(-((p*t2)/m) + x))/hbar + ((I/2)*q1*(q2*t1 - 2*p*(t1 + t2) + 2*m*x))/(hbar*m) - (p - q1/2 - q2/2)^2/(2*σp^2) - (-q + q1)^2/(2*σq^2) - (-q + q2)^2/(2*σq^2) - (q2*t1 - 2*p*(t1 + t2) + 2*m*x)^2/(8*m^2*σx^2)))/(Pi*σq^2)",
       "mime": "text/html"
      }
