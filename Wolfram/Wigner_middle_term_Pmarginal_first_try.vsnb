       "data": "<div class=\"wexpr\"><wgraph class=\"resizable\" style=\"width:810px;height:182px;\" aspect-ratio=\"0.2243\" tabIndex=\"-1\"><img class=\"invert-brightness\" src=\"data:image/png;base64,\" /></wgraph></div>",
