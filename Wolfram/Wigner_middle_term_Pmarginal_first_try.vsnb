    {
     "items": [
      {
       "data": "E^(X^2/(2*σx^2))*(E^(I*(d + e) + (a + I*(-b - c))^2/(4*M)) + E^(I*(d - e) + (a + I*(b - c))^2/(4*M)) + E^(I*(-d + e) + (a + I*(-b + c))^2/(4*M)) + E^(I*(-d - e) + (a + I*(b + c))^2/(4*M)))*Sqrt[M^(-1)]*Sqrt[Pi]",
       "mime": "text/html"
      }
     ],
     "id": "f5913ba6-b795-4c5c-b23b-03404c27acb2"
