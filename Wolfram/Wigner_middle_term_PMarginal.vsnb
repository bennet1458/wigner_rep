{
 "cells": [
  {
   "kind": 2,
   "value": "ClearAll[a, b, c, b1, c1, b2, c2]\r\n\r\nresult = Sqrt[Pi/a]*Exp[c]*(Exp[(b+I*(b1+b2))^2/(4*a)+I*c1+I*c2]\r\n                    +Exp[(b+I*(b1-b2))^2/(4*a)+I*c1-I*c2]\r\n                    +Exp[(b+I*(-b1+b2))^2/(4*a)-I*c1+I*c2]\r\n                    +Exp[(b+I*(-b1-b2))^2/(4*a)-I*c1-I*c2])",
   "languageId": "wolfram",
   "outputs": [
    {
     "items": [
      {
       "data": "<div class=\"wexpr\"><wgraph class=\"resizable\" style=\"width:696px;height:42px;\" aspect-ratio=\"0.0598\" tabIndex=\"-1\"><img class=\"invert-brightness\" src=\"data:image/png;base64,\" /></wgraph></div>",
