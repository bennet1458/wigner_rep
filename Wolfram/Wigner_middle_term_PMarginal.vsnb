    {
     "items": [
      {
       "data": "E^(-1/8*(q1 + q2)^2/σp^2 - (q2^2*t2^2)/(4*hbar^2*m^2*(1/(2*σp^2) + (t1 + t2)^2/(2*m^2*σx^2))) - (q1^2*(t1 + t2)^2)/(4*hbar^2*m^2*(1/(2*σp^2) + (t1 + t2)^2/(2*m^2*σx^2))) + ((q1 + q2)/(4*σp^2) + ((t1 + t2)*((q2*t1)/m + x))/(m*σx^2))^2/(4*(1/(2*σp^2) + (t1 + t2)^2/(2*m^2*σx^2))) - ((q2*t1)/m + x)^2/(2*σx^2))*(E^(I*(q1/hbar + (q1*q2*t1)/(2*hbar*m)) + (I*q2*x)/hbar - (q1*q2*t2*(t1 + t2))/(2*hbar^2*m^2*(1/(2*σp^2) + (t1 + t2)^2/(2*m^2*σx^2))) - ((I/2)*q2*t2*((q1 + q2)/(4*σp^2) + ((t1 + t2)*((q2*t1)/m + x))/(m*σx^2)))/(hbar*m*(1/(2*σp^2) + (t1 + t2)^2/(2*m^2*σx^2))) - ((I/2)*q1*(t1 + t2)*((q1 + q2)/(4*σp^2) + ((t1 + t2)*((q2*t1)/m + x))/(m*σx^2)))/(hbar*m*(1/(2*σp^2) + (t1 + t2)^2/(2*m^2*σx^2)))) + E^(I*(q1/hbar + (q1*q2*t1)/(2*hbar*m)) - (I*q2*x)/hbar + (q1*q2*t2*(t1 + t2))/(2*hbar^2*m^2*(1/(2*σp^2) + (t1 + t2)^2/(2*m^2*σx^2))) + ((I/2)*q2*t2*((q1 + q2)/(4*σp^2) + ((t1 + t2)*((q2*t1)/m + x))/(m*σx^2)))/(hbar*m*(1/(2*σp^2) + (t1 + t2)^2/(2*m^2*σx^2))) - ((I/2)*q1*(t1 + t2)*((q1 + q2)/(4*σp^2) + ((t1 + t2)*((q2*t1)/m + x))/(m*σx^2)))/(hbar*m*(1/(2*σp^2) + (t1 + t2)^2/(2*m^2*σx^2)))) + E^((-I)*(q1/hbar + (q1*q2*t1)/(2*hbar*m)) + (I*q2*x)/hbar + (q1*q2*t2*(t1 + t2))/(2*hbar^2*m^2*(1/(2*σp^2) + (t1 + t2)^2/(2*m^2*σx^2))) - ((I/2)*q2*t2*((q1 + q2)/(4*σp^2) + ((t1 + t2)*((q2*t1)/m + x))/(m*σx^2)))/(hbar*m*(1/(2*σp^2) + (t1 + t2)^2/(2*m^2*σx^2))) + ((I/2)*q1*(t1 + t2)*((q1 + q2)/(4*σp^2) + ((t1 + t2)*((q2*t1)/m + x))/(m*σx^2)))/(hbar*m*(1/(2*σp^2) + (t1 + t2)^2/(2*m^2*σx^2)))) + E^((-I)*(q1/hbar + (q1*q2*t1)/(2*hbar*m)) - (I*q2*x)/hbar - (q1*q2*t2*(t1 + t2))/(2*hbar^2*m^2*(1/(2*σp^2) + (t1 + t2)^2/(2*m^2*σx^2))) + ((I/2)*q2*t2*((q1 + q2)/(4*σp^2) + ((t1 + t2)*((q2*t1)/m + x))/(m*σx^2)))/(hbar*m*(1/(2*σp^2) + (t1 + t2)^2/(2*m^2*σx^2))) + ((I/2)*q1*(t1 + t2)*((q1 + q2)/(4*σp^2) + ((t1 + t2)*((q2*t1)/m + x))/(m*σx^2)))/(hbar*m*(1/(2*σp^2) + (t1 + t2)^2/(2*m^2*σx^2)))))*Sqrt[Pi]*Sqrt[(1/(2*σp^2) + (t1 + t2)^2/(2*m^2*σx^2))^(-1)]",
       "mime": "text/html"
      }
