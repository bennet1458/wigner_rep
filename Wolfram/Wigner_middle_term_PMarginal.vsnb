  {
   "kind": 2,
   "value": "replace = {\r\na -> 1/(2*\\[Sigma]x^2)*((t1+t2)/m)^2+1/(2*\\[Sigma]p^2),\r\nb -> 1/(2*\\[Sigma]x^2)*2*(t1+t2)/m*(x+q2*t1/m)+1/(2*\\[Sigma]p^2)*(q1+q2)/2,\r\nc -> -1/(2*\\[Sigma]x^2)*(x+q2*t1/m)^2-1/(2*\\[Sigma]p^2)*((q1+q2)/2)^2,\r\nb1 -> -q2*t2/(hbar*m),\r\nc1 -> q2*x/hbar,\r\nb2 -> -q1*(t1+t2)/(hbar*m),\r\nc2 -> q1/hbar + q1*q2*t1/(2*hbar*m)\r\n};\r\n\r\nres3 = res2 /. replace\r\nInputForm[res3]",
   "languageId": "wolfram",
   "outputs": [
    {
     "items": [
