    {
     "items": [
      {
       "data": "Sqrt[a^(-1)]*E^(b^2/(4*a) - b1^2/(4*a) - b2^2/(4*a) + c)*(E^(((-1/2*I)*b*b1)/a - ((I/2)*b*b2)/a - (b1*b2)/(2*a) - I*c1 - I*c2) + E^(((I/2)*b*b1)/a - ((I/2)*b*b2)/a + (b1*b2)/(2*a) + I*c1 - I*c2) + E^(((-1/2*I)*b*b1)/a + ((I/2)*b*b2)/a + (b1*b2)/(2*a) - I*c1 + I*c2) + E^(((I/2)*b*b1)/a + ((I/2)*b*b2)/a - (b1*b2)/(2*a) + I*c1 + I*c2))*Sqrt[Pi]",
       "mime": "text/html"
      }
     ],
     "id": "30505d35-8b62-46ca-a442-953292889f26"
    }
   ],
   "metadata": {},
   "executionSummary": {}
