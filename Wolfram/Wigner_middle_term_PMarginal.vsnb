   ],
   "metadata": {},
   "executionSummary": {}
  },
  {
   "kind": 2,
   "value": "res = result /. Exp[arg_] :> Exp[Expand[arg]]\r\nfac = Sqrt[Pi/a]*Exp[c + b^2/(4*a) - b1^2/(4*a) - b2^2/(4*a)];\r\n\r\nres2 = fac * Expand[res/fac] \r\nInputForm[res2]",
   "languageId": "wolfram",
   "outputs": [
    {
     "items": [
      {
       "data": "<div class=\"wexpr\"><wgraph class=\"resizable\" style=\"width:1055px;height:41px;\" aspect-ratio=\"0.0387\" tabIndex=\"-1\"><img class=\"invert-brightness\" src=\"data:image/png;base64,\" /></wgraph></div>",
