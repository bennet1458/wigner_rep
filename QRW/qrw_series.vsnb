   "kind": 2,
   "value": "u[n_, l_] :=\r\n  Sum[\r\n    Binomial[n - 1 - k, k]\r\n    (l)^k\r\n    ((l - 1)/Sqrt[2])^(n - 1 - 2 k),\r\n    {k, -1, Floor[(n - 1)/2]}\r\n  ];\r\n  \r\n\\[Psi]nDER[n_, \\[Phi]_] :=\r\n  1/Sqrt[2] {\r\n    Sqrt[2] u[n + 1, Exp[-I \\[Phi]]] +\r\n      u[n, Exp[-I \\[Phi]]],\r\n    u[n, Exp[-I \\[Phi]]]\r\n  };",
