  {
   "kind": 2,
   "value": "Clear[x, y, F]\r\n\r\nx[ϕ_] := (Exp[-I ϕ] - 1)/Sqrt[2];\r\ny[ϕ_] := Exp[-I ϕ];\r\n\r\nF[n_, ϕ_] :=\r\n Sum[\r\n   Binomial[n - k, k] y[ϕ]^k x[ϕ]^(n - 2 k),\r\n   {k, 0, Floor[n/2]}\r\n ];\r\n\r\nFabsNumeric[n_] := Module[{data, fftResult},\r\n  data = Chop[N[Table[Abs[F[n, ϕ]], {ϕ, -Pi, Pi, 2Pi/1024}], 20], 10^-15];\r\n  fftResult = Abs[Fourier[data]]^2;\r\n  fftResult\r\n];\r\n\r\nListPlot[\r\n FabsNumeric[100],\r\n PlotRange -> All,\r\n AxesLabel -> {\"Frequency\", \"|F|^2\"},\r\n PlotLabel -> \"Fourier Transform of F[100, ϕ]\"\r\n]\r\n\r\n",
   "languageId": "wolfram",
   "outputs": [
