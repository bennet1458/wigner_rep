  {
   "kind": 2,
   "value": "c[n_, r_] := \r\n  Sum[(-1)^(n - 1 - r - k) 2^(k - n/2)\r\n     Binomial[n - 1 - k, k] Binomial[n - 1 - 2*k, r - k], {k, 0, \r\n    Min[r, n - 1 - r]}];\r\nS[n_, q_] := Sum[c[n, m] q^m, {m, 0, n - 1}];\r\n\\[Psi]nGPT[n_, \\[Phi]_] := \r\n  Simplify[{Sqrt[2] S[n + 1, Exp[-I \\[Phi]]] + S[n, Exp[-I \\[Phi]]], \r\n    S[n, Exp[-I \\[Phi]]]}, \\[Phi] \\[Element] Reals];",
   "languageId": "wolfram",
   "outputs": [
    {
     "items": [
      {
       "data": "2^{-n/2} \\left(-(-1)^{n-r}\\right) \\binom{n-1}{r} \\, _2F_1(-r,-n+r+1;1-n;2)",
       "mime": "text/html"
      }
     ],
     "id": "7a92d6be-c26b-41ab-a5fd-984d99976937"
