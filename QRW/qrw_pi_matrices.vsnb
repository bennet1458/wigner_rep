       "data": "\\left\\{\\left\\{k\\to -2 \\sec ^{-1}\\left(\\frac{2 i \\sqrt{p} \\sqrt{p-n}}{n-2 p}\\right)\\right\\},\\left\\{k\\to 2 \\sec ^{-1}\\left(\\frac{2 i \\sqrt{p} \\sqrt{p-n}}{n-2 p}\\right)\\right\\},\\left\\{k\\to -2 \\cos ^{-1}\\left(\\frac{i (n-2 p)}{2 \\sqrt{p} \\sqrt{p-n}}\\right)\\right\\},\\left\\{k\\to 2 \\cos ^{-1}\\left(\\frac{i (n-2 p)}{2 \\sqrt{p} \\sqrt{p-n}}\\right)\\right\\}\\right\\}",
